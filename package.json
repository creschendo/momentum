{
  "name": "momentum",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm --prefix client run build",
    "start": "tsx server/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck:client": "npm --prefix client run typecheck",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "db:migrate": "npm --prefix server run db:migrate",
    "seed:user": "npm --prefix server run seed:user",
    "auth:setup": "npm --prefix server run auth:setup"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.8.2",
    "vitest": "^1.3.0"
  }
}
