{
  "name": "momentum-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/migrate.mjs",
    "seed:user": "node scripts/seed-auth-user.mjs",
    "auth:setup": "npm run db:migrate && npm run seed:user"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "momentum": "file:..",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.13.10",
    "@types/pino-http": "^5.8.4",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0"
