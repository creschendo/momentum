# CalorieNinjas API credentials
# Get your free API key at https://calorieninjas.com/api
CALORIENINJAS_API_KEY=

# Server port
PORT=4000

# Database
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=momentum

# CORS — comma-separated list of allowed origins (leave unset to default to localhost:5173)
CORS_ORIGIN=

# Logging — debug | info | warn | error (default: info)
LOG_LEVEL=info

# Environment
NODE_ENV=development
